# ─── Backend API ────────────────────────────────────────────────────────────────
# The base URL of the FastAPI backend.
VITE_API_BASE_URL=https://app.hellum.dev

# ─── Google OAuth ────────────────────────────────────────────────────────────────
# Google OAuth 2.0 Client ID (used by @react-oauth/google for the Sign-In button).
# Get this from: https://console.cloud.google.com/apis/credentials
# Must be the same GOOGLE_CLIENT_ID used in the backend .env.
VITE_GOOGLE_CLIENT_ID=950018491746-2bu29f12geobou3fb0djh2m2q38jb9a8.apps.googleusercontent.com

# ─── MQTT (WebSocket) ────────────────────────────────────────────────────────────
# Secure WebSocket URL for the Mosquitto MQTT broker (must be wss:// for HTTPS PWA).
# Requires Mosquitto configured with a websockets listener.
VITE_MQTT_WS_URL=wss://mqtt.hellum.dev:8084

# Optional: MQTT broker credentials (if the WebSocket listener requires auth)
# VITE_MQTT_USERNAME=
# VITE_MQTT_PASSWORD=
